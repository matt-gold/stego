{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Stego Extension (Monorepo)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/stego-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/stego-extension/out/**/*.js"
      ],
      "preLaunchTask": "stego-extension: compile"
    }
  ]
}
