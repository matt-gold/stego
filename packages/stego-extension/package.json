{
  "name": "stego-extension",
  "displayName": "Stego",
  "description": "The official UI companion to Stego CLI, providing a user-friendly sidebar for managing manuscripts, comments, project browsing, validation and export in VS Code.",
  "version": "1.0.0",
  "publisher": "matt-gold",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/matt-gold/stego.git",
    "directory": "packages/stego-extension"
  },
  "icon": "assets/stego.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:stegoSpine.reloadIndex",
    "onCommand:stegoSpine.runBuild",
    "onCommand:stegoSpine.runGateStage",
    "onCommand:stegoSpine.newManuscript",
    "onCommand:stegoSpine.insertImage",
    "onCommand:stegoSpine.newProject",
    "onCommand:stegoSpine.openProject",
    "onCommand:stegoSpine.addComment",
    "onCommand:stegoSpine.toggleFrontmatter",
    "onView:stegoSpine.metadataView"
  ],
  "main": "./out/stego-extension/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stegoSpine",
          "title": "Stego",
          "icon": "assets/stego.svg"
        }
      ]
    },
    "views": {
      "stegoSpine": [
        {
          "id": "stegoSpine.metadataView",
          "name": "Stego",
          "type": "webview",
          "icon": "assets/stego.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "stegoSpine.reloadIndex",
        "title": "Stego: Rebuild Index"
      },
      {
        "command": "stegoSpine.runBuild",
        "title": "Stego: Compile Full Manuscript",
        "icon": "$(file)"
      },
      {
        "command": "stegoSpine.newManuscript",
        "title": "Stego: New Manuscript",
        "icon": "$(add)"
      },
      {
        "command": "stegoSpine.insertImage",
        "title": "Stego: Insert Image (Copy to Project Assets)",
        "icon": "$(file-media)"
      },
      {
        "command": "stegoSpine.newProject",
        "title": "Stego: New Stego Project"
      },
      {
        "command": "stegoSpine.openProject",
        "title": "Stego: Open Project",
        "icon": "$(folder-opened)"
      },
      {
        "command": "stegoSpine.runGateStage",
        "title": "Stego: Run Stage Checks",
        "icon": "$(check)"
      },
      {
        "command": "stegoSpine.runLocalValidate",
        "title": "Stego: Validate Current File",
        "icon": "$(verified)"
      },
      {
        "command": "stegoSpine.toggleFrontmatter",
        "title": "Stego: Toggle Frontmatter Fold"
      },
      {
        "command": "stegoSpine.addComment",
        "title": "Stego: Add Comment"
      }
    ],
    "keybindings": [
      {
        "command": "stegoSpine.addComment",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "stegoSpine.newManuscript",
          "when": "view == stegoSpine.metadataView && !stegoSpine.isStegoWorkspace",
          "group": "navigation@0"
        },
        {
          "command": "stegoSpine.openProject",
          "when": "view == stegoSpine.metadataView && stegoSpine.isStegoWorkspace",
          "group": "navigation@0"
        },
        {
          "command": "stegoSpine.newProject",
          "when": "view == stegoSpine.metadataView && stegoSpine.isStegoWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "stegoSpine.runBuild",
          "when": "view == stegoSpine.metadataView && !stegoSpine.isStegoWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "stegoSpine.runGateStage",
          "when": "view == stegoSpine.metadataView && !stegoSpine.isStegoWorkspace",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Stego",
      "properties": {
        "stego.spine.identifierPattern": {
          "type": "string",
          "default": "\\b[A-Z][A-Z0-9]*-[A-Z0-9]+(?:-[A-Z0-9]+)*\\b",
          "description": "Regex used to find Spine identifiers in Markdown text (for example LOC-ASDF or CHAR-JANE)."
        },
        "stego.spine.definitionBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional fallback base URL used when a Spine identifier has no local file target."
        },
        "stego.spine.reportUnknownIdentifiers": {
          "type": "boolean",
          "default": true,
          "description": "Warn when identifiers are found in text but missing from the configured Spine categories."
        },
        "stego.editor.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "Show identifier details on hover."
        },
        "stego.editor.linkInCodeFences": {
          "type": "boolean",
          "default": false,
          "description": "Create links inside fenced code blocks."
        },
        "stego.editor.autoFoldFrontmatter": {
          "type": "boolean",
          "default": true,
          "description": "Automatically fold YAML frontmatter in Markdown files."
        },
        "stego.comments.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the comments feature. When disabled, no comment parsing, gutter decorations, or comments tab will appear."
        },
        "stego.comments.author": {
          "type": "string",
          "default": "",
          "description": "Default author name used when adding sidebar comments. Leave blank to use your system/git username."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run compile:host && npm run compile:webview",
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "compile:host": "npm run -w @stego/shared compile && npm run clean && tsc -p tsconfig.build.json",
    "compile:webview": "vite build --config webview/sidebar/vite.config.ts",
    "watch": "tsc -watch -p ./",
    "watch:webview": "vite build --watch --config webview/sidebar/vite.config.ts",
    "vscode:prepublish": "npm run compile",
    "test": "npm run test:pure && npm run test:webview",
    "test:pure": "npm run compile:host && node --test out/stego-extension/src/test/pure/*.js",
    "test:webview": "vitest run --config webview/sidebar/vite.config.ts",
    "package": "vsce package",
    "changeset": "changeset",
    "release:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.7.1",
    "jsdom": "^27.0.0",
    "solid-js": "^1.9.9",
    "vite": "^7.1.4",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^3.2.4",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@stego/shared": "^1.0.0",
    "dayjs": "^1.11.19",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.1"
  }
}
