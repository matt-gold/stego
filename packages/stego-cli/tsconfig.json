{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@cli/*": [
        "src/*"
      ],
      "@engine/*": [
        "../stego-engine/src/*"
      ],
      "@stego/shared": [
        "../shared/src/index.ts"
      ],
      "@stego/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "tools/stego-cli.ts",
    "../stego-engine/src/**/*.ts",
    "../stego-engine/src/**/*.tsx",
    "../shared/src/**/*.ts"
  ]
}
